---
import MainLayout from "../layouts/MainLayout.astro";
import Button from '../components/Button.astro';
import Inputfield from "../components/Inputfield.astro";
import Resultcards from "../components/Resultcards.astro";
import Dotcircle from "../components/Dotcircle.astro";
---

<MainLayout title="Divide · Calculate your rent based on your income">
<div class="bg-base min-h-screen px-4 md:px-6 lg:px-8 py-10 md:py-16 lg:py-20">

  <!-- Heading — always full width -->
 

  <!-- Two column layout on md+ — left: circle + results / right: inputs + CTAs -->
  <div class="w-full flex flex-col md:flex-row md:gap-12 lg:gap-20 md:items-start">

    <!-- LEFT COLUMN — circle + results -->
    <div id="results-top" class="w-full md:w-1/2 flex flex-col gap-4 md:sticky md:top-10">
       <div class="w-full mb-2 md:mb-12">
    <h1 class="text-accent text-6xl font-bold font-['Doto'] mb-4">
      Divide
    </h1>
    <p class="text-primary text-base md:text-lg font-light font-body leading-relaxed">
      Split rent objective. Fairly based on income.
    </p>

     <p class="mt-2 text-primary opacity-40 text-s md:text-base font-light font-body leading-relaxed">
      Ensures both partners maintain a comparable quality of life and can save equally for the future.
    </p>
  </div>
      <!-- Circle -->
      <Dotcircle />

    </div>

    <!-- RIGHT COLUMN — inputs + CTAs -->
    <div class="w-full md:w-1/2 flex flex-col gap-4 mt-8 md:mt-0">
      <!-- Result cards -->
      <Resultcards person1Amount="0" person2Amount="0" />

      <h1 class="text-primary text-xl font-light font-body tracking-wide md:text-2xl lg:text-3xl">
      Calculate your split
      </h1>
      <!-- Input fields -->
      <div class="w-full flex flex-col gap-2 md:gap-3">

        <!-- Total rent — full width -->
        <Inputfield
          id="total-rent"
          label="Total rent"
          subtitle="Insert full amount of rent"
        />

        <!-- Person 1 + Person 2 — side by side -->
        <div class="w-full flex gap-4 md:gap-6">
          <Inputfield
            id="person-1"
            label="Person 1"
            subtitle="Insert income"
          />
          <Inputfield
            id="person-2"
            label="Person 2"
            subtitle="Insert income"
          />
        </div>
      </div>

      <!-- Action buttons -->
      <div class="w-full flex gap-2 md:gap-3">
        <div class="flex-1">
          <Button id="btn-reset" variant="secondary" size="medium">Reset values</Button>
        </div>
        <div class="flex-1">
          <Button id="btn-calculate" variant="primary" size="medium">Calculate</Button>
        </div>
      </div>

    </div>
  </div>

</div>
</MainLayout>

<script>
  // ── Element refs ─────────────────────────────────────────
  const inputTotalRent = document.getElementById("total-rent") as HTMLInputElement;
  const inputPerson1   = document.getElementById("person-1")   as HTMLInputElement;
  const inputPerson2   = document.getElementById("person-2")   as HTMLInputElement;

  const resultAmount1  = document.getElementById("result-amount-1");
  const resultAmount2  = document.getElementById("result-amount-2");

  const btnCalculate   = document.getElementById("btn-calculate");
  const btnReset       = document.getElementById("btn-reset");

  // ── Core calculation ──────────────────────────────────────
  function calculate() {
    const rent    = parseFloat(inputTotalRent?.value) || 0;
    const income1 = parseFloat(inputPerson1?.value)   || 0;
    const income2 = parseFloat(inputPerson2?.value)   || 0;

    const totalIncome = income1 + income2;

    if (totalIncome === 0 || rent === 0) {
      setResults("—", "—");
      (window as any).updateCircle?.(-1);
      return;
    }

    const pct1 = income1 / totalIncome;
    const pct2 = income2 / totalIncome;

    const pay1 = (rent * pct1).toFixed(0);
    const pay2 = (rent * pct2).toFixed(0);

    setResults(pay1, pay2);
    (window as any).updateCircle?.(pct1);
  }

  // ── Calculate + scroll — CTA only ────────────────────────
  function calculateAndScroll() {
    calculate();
    if (window.innerWidth < 768) {
      document.getElementById("results-top")?.scrollIntoView({ behavior: "smooth" });
    }
  }

  // ── Update result amounts ─────────────────────────────────
  function setResults(amount1: string, amount2: string) {
    if (resultAmount1) resultAmount1.textContent = amount1;
    if (resultAmount2) resultAmount2.textContent = amount2;
  }

  // ── Reset ─────────────────────────────────────────────────
  function reset() {
    if (inputTotalRent) inputTotalRent.value = "";
    if (inputPerson1)   inputPerson1.value   = "";
    if (inputPerson2)   inputPerson2.value   = "";
    setResults("0", "0");
    (window as any).updateCircle?.(-1);
  }

  // ── Event listeners ───────────────────────────────────────
  inputTotalRent?.addEventListener("input", calculate);
  inputPerson1?.addEventListener("input", calculate);
  inputPerson2?.addEventListener("input", calculate);

  btnCalculate?.addEventListener("click", calculateAndScroll);
  btnReset?.addEventListener("click", reset);
</script>