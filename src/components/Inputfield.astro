---
const {
  label,
  subtitle,
  id,
  placeholder = "0",
} = Astro.props;
---

<div class="w-full p-4 bg-surface rounded-2xl flex flex-col justify-start items-start gap-0.5 md:p-5 lg:p-6">

  <!-- Label -->
  <label for={id} class="w-full text-primary text-base font-light font-body md:text-2xl">
    {label}
  </label>

  <!-- Optional Subtitle -->
  {subtitle && (
    <span class="w-full text-secondary text-xs font-light font-body md:text-sm">
      {subtitle}
    </span>
  )}

  <!-- Input row — value + currency symbol -->
  <div class="w-full flex flex-row justify-between items-center">
    <input
      type="number"
      id={id}
      name={id}
      min="0"
      placeholder={placeholder}
      class="
        w-full h-10
        text-primary text-2xl font-bold font-['Doto']
        bg-transparent border-none outline-none
        placeholder:text-primary
        [appearance:textfield]
        [&::-webkit-outer-spin-button]:appearance-none
        [&::-webkit-inner-spin-button]:appearance-none
        md:text-3xl md:h-12
        lg:text-4xl lg:h-14
      "
    />
    <span class="text-primary text-2xl font-bold font-['Doto'] pl-1 md:text-3xl lg:text-4xl">
      €
    </span>
  </div>

</div>