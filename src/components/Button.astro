---
const { variant = "primary", size = "medium", id } = Astro.props;

// Base styling — shared across all buttons
const buttonStyling = "w-full rounded-3xl inline-flex justify-center items-center cursor-pointer transition-opacity duration-200 hover:opacity-80 active:opacity-60";

// Variant styling
const variantClasses = {
  "primary":   "bg-accent text-primary",
  "secondary": "bg-transparent text-primary outline outline-1 outline-dashed outline-accent",
};

// Size styling — responsive, Tailwind values only
const sizeClasses = {
  "large":  "h-11 px-8 text-xl font-bold font-['Doto'] md:h-12 md:px-10 md:text-2xl lg:h-14 lg:px-12 lg:text-3xl",
  "medium": "h-11 px-6 text-base font-bold font-['Doto'] md:h-11 md:px-7 md:text-lg lg:h-12 lg:px-8 lg:text-xl",
  "small":  "h-9  px-4 text-sm  font-bold font-['Doto'] md:h-10 md:px-5 md:text-base lg:h-11 lg:px-6 lg:text-lg",
};
---

<button id={id} class:list={[buttonStyling, variantClasses[variant], sizeClasses[size]]}>
  <slot />
</button>